# 推荐：在仓库根目录使用 .env（见 ../../.env.example），run_nim / check_env 会自动加载。
# 若坚持用本文件，可手动：set -a && source ../../.env && set +a

# NGC_API_KEY='...'

# Optional: override image (partner registry or specific tag)
# NIM_IMAGE='nvcr.io/nim/nvidia/domino-automotive-aero:2.0.0'
# NIM_TAG='2.0.0'
# NIM_PORT=8000

# Skip docker login nvcr.io when using partner registry (see root README path A)
# SKIP_DOCKER_LOGIN=1

# Python downloads (HF STL) — shell only; does not affect docker pull
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890
